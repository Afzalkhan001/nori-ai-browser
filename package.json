{
  "name": "nori",
  "version": "0.1.2",
  "description": "Nori — the AI-native productivity browser",
  "main": "./out/main/index.js",
  "author": "Afzal Khan",
  "homepage": "https://github.com/Afzalkhan001/nori-ai-browser",
  "repository": {
    "type": "git",
    "url": "https://github.com/Afzalkhan001/nori-ai-browser.git"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "icon": "node scripts/generate-icon.cjs",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "release": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "openai": "^6.45.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.afzalkhan.nori",
    "productName": "Nori",
    "copyright": "Copyright © 2026 Afzal Khan",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**"
    ],
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "Afzalkhan001",
      "repo": "nori-ai-browser"
    },
    "releaseInfo": {
      "releaseNotes": "Nori 0.1.2 — the AI browser that acts for you.\n\nWhat's new\n• First-run setup: Nori now walks you through connecting an AI provider on launch.\n• Bring your own FREE key — no OpenAI credits needed. Pick OpenRouter, Groq, or Google Gemini (all free tiers) right in the app; OpenAI and local Ollama also supported.\n• Autonomous Agents + teachable Skills, and universal page interaction (click / fill / submit).\n\nInstalling on Windows\nThe app is not code-signed yet, so Windows SmartScreen shows a blue \"Windows protected your PC\" prompt. This is expected for indie apps — click More info → Run anyway. On macOS, right-click the app → Open → Open.\n\nFirst run\nWhen Nori opens, connect a provider (OpenRouter is free and recommended). Your key is stored only on your device. For Google/OAuth sign-in and dev features, you can also clone & run from source: https://github.com/Afzalkhan001/nori-ai-browser\n\nUpdates install automatically from here on."
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nori"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "Nori ${version}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Network"
    }
  }
}
